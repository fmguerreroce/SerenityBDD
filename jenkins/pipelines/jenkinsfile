pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK11'
    }

    parameters {
        string(name: 'TAGS', defaultValue: '', description: 'Cucumber tags')
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/fmguerreroce/SerenityBDD.git'
            }
        }

        stage('Clean & Test') {
            steps {
                script {
                    if (params.TAGS?.trim()) {
                        bat "mvn clean verify -Dcucumber.filter.tags=${params.TAGS}"
                    } else {
                        bat "mvn clean verify"
                    }
                }
            }
        }

        stage('Generate Serenity Report') {
            steps {
                bat "mvn serenity:aggregate"
            }
        }

        stage('Publish Serenity Report') {
            steps {
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'target/site/serenity',
                    reportFiles: 'index.html',
                    reportName: 'Serenity Report'
                ])
            }
        }
    }

    post {
        always {
            junit 'target/surefire-reports/*.xml'
        }
    }
}