pipeline {
    agent any

parameters {

    choice(
        name: 'FEATURE_FOLDER',
        choices: [
            '',
            'web'
        ],
        description: 'Seleccione carpeta de features (vacio = todas)'
    )

    choice(
        name: 'TAGS',
        choices: [
            '',
            '@ESC01_COMPRAA',
            '@ESC02_LOGIN',
            '@ESC03_PAGO',
            '@REGRESION',
            '@SMOKE'
        ],
        description: 'Seleccione el tag de Cucumber (vacio = todos)'
    )
}
    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/fmguerreroce/SerenityBDD.git'
            }
        }

        stage('Clean & Test') {
            steps {
                script {

                    def command = "mvn clean verify"

                    if (params.FEATURE_FOLDER?.trim()) {
                        command += " -Dcucumber.features=src/test/resources/features/${params.FEATURE_FOLDER}"
                    }

                    if (params.TAGS?.trim()) {
                        command += " -Dcucumber.filter.tags=${params.TAGS}"
                    }

                    bat command
                }
            }
        }

        stage('Generate Serenity Report') {
            steps {
                bat "mvn serenity:aggregate"
            }
        }

        stage('Publish Serenity Report') {
            steps {
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'target/site/serenity',
                    reportFiles: 'index.html',
                    reportName: 'Serenity Report'
                ])
            }
        }
    }

    post {
        always {
            junit 'target/failsafe-reports/*.xml'

            emailext(
                subject: "Resultado Ejecución Serenity - ${currentBuild.currentResult}",
                body: """
                <h2>Resultado de la ejecución</h2>
                <p><b>Estado:</b> ${currentBuild.currentResult}</p>
                <p><b>Tag ejecutado:</b> ${params.TAGS ?: 'Todos'}</p>
                <p>Ver reporte completo en Jenkins:</p>
                <a href="${env.BUILD_URL}Serenity_Report/">Abrir Reporte Serenity</a>
                """,
                to: "florguerreroceballos@gmail.com",
                mimeType: 'text/html'
            )
        }
    }
}

